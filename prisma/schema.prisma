// Prisma schema for AI Tutor Bot for Kids

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String        @default("credentials") // "credentials" | "google"
  grade         Int           @default(8) // class 1-10
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  questions     Question[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Question {
  id           String       @id @default(cuid())
  userId       String
  subject      String       // "maths" | "hindi" | "science" | "kannada"
  question     String
  style        String       // explanation style used
  language     String       @default("en") // voice-over language
  answer       String
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@index([identifier])
}
