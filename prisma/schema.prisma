// Prisma schema for AI Tutor Bot for Kids (WonderWhiz)
// Extended: parent dashboard, progress tracking, question banks, achievements

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  // Postgres is used in production (Vercel + Neon). SQLite is used for local
  // dev (DATABASE_URL=file:./dev.db in .env). Prisma accepts either based on
  // the URL scheme — the provider stays "postgresql" because that's the
  // remote DB and the only one that matters for the deploy.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  image         String?
  provider      String        @default("credentials") // "credentials" | "google"
  role          String        @default("student") // "student" | "parent"
  grade         Int           @default(8) // class 1-12 (K-12)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  questions     Question[]
  attempts      PracticeAttempt[]
  achievements  UserAchievement[]
  // Parent relationships
  childrenLinks ParentStudent[] @relation("ParentChildren")
  parentLinks    ParentStudent[] @relation("ParentOfStudent")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Question {
  id           String       @id @default(cuid())
  userId       String
  subject      String       // "maths" | "hindi" | "science" | "kannada"
  topic        String?      // e.g. "algebra", "calculus", "geometry" (maths only)
  question     String
  style        String       // explanation style used
  language     String       @default("en") // voice-over language
  answer       String
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([subject, topic])
}

// Pre-built question bank for practice (per grade / subject / topic)
model QuestionBank {
  id           String       @id @default(cuid())
  grade        Int          // 1-12
  subject      String       // "maths" | "science" | "hindi" | "kannada"
  topic        String       // e.g. "algebra", "geometry", "trigonometry"
  difficulty   String       @default("easy") // easy | medium | hard
  question     String       // question text
  options      String?      // JSON array of MCQ options (null = free response)
  correctAnswer String      // correct answer text
  hint         String?
  explanation  String?
  createdAt    DateTime     @default(now())
  attempts     PracticeAttempt[]

  @@index([grade, subject, topic])
  @@index([subject, topic])
}

// Student's attempt at a question-bank item
model PracticeAttempt {
  id             String        @id @default(cuid())
  userId         String
  questionBankId String
  userAnswer     String
  isCorrect      Boolean
  timeSpentSec   Int           @default(0)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       QuestionBank  @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionBankId])
  @@index([createdAt])
}

model Achievement {
  id           String             @id @default(cuid())
  code         String             @unique // e.g. "first_question", "streak_7", "math_master"
  name         String
  description  String
  emoji        String
  // earned by:
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String       @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// Links a parent user to a student user (so parents can monitor)
model ParentStudent {
  id         String   @id @default(cuid())
  parentId   String
  studentId  String
  createdAt  DateTime @default(now())
  parent     User     @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  student    User     @relation("ParentOfStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@index([identifier])
}
