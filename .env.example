# WonderWhiz environment variables
# Copy this file to `.env` for local dev, or set these in Vercel's project settings.

# ---- Database ----
# Local SQLite (default, works on dev machines):
DATABASE_URL="file:/home/z/my-project/db/custom.db"
#
# For Vercel / serverless deployment, you MUST switch to a networked DB.
# Recommended: Turso (libSQL) — works with the existing Prisma schema.
#   1. Create a free DB at https://turso.tech
#   2. Run `turso db tokens create <your-db>` to get an auth token.
#   3. Set DATABASE_URL="libsql://<your-db>.turso.io?authToken=<token>"
#
# Alternative: any Postgres provider (Neon, Supabase, Vercel Postgres). If you
# switch to Postgres, also update prisma/schema.prisma `provider = "postgresql"`.

# ---- NextAuth ----
# Required: a long random string used to sign session JWTs.
# Generate one with: `openssl rand -base64 32`
NEXTAUTH_SECRET="dev-secret-change-me-in-production"
#
# Required in production: the canonical public URL of your app.
# Local dev:        http://localhost:3000
# Vercel:           https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (optional) ----
# Only required if you want "Continue with Google" sign-in.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add your deployed URL + http://localhost:3000 to Authorized redirect URIs.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- z-ai-web-dev-sdk (used for AI tutor + TTS) ----
# Already configured in this workspace; on Vercel you'll need to provide it.
ZAI_API_KEY=""
